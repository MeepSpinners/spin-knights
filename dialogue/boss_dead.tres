[sub_resource type="Resource" id="Resource_wgosi"]
script = ExtResource("1_8g608")
text = "I'm looking at the email I received... and the address is wrong... I thought it said 313 Avenue Street, but it actually said 133 Street Avenue!"
speaker1 = ExtResource("2_wgosi")
speaker2 = ExtResource("4_2qc6r")
metadata/_custom_type_script = "uid://dxc3ltvbb58ih"

[sub_resource type="Resource" id="Resource_oao8a"]
script = ExtResource("1_8g608")
text = "I guess I'll be heading there next... that should be where my actual new job is. Thanks for everything, I guess."
speaker1 = ExtResource("2_wgosi")
speaker2 = ExtResource("4_2qc6r")
