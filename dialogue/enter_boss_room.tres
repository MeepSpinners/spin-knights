[sub_resource type="Resource" id="Resource_c5twe"]
script = ExtResource("1_ku56k")
text = "Umm... Hi boss! It's supposed to be my first day here..."
speaker1 = ExtResource("2_cndc5")
speaker2 = ExtResource("3_b73wo")
metadata/_custom_type_script = "uid://dxc3ltvbb58ih"

[sub_resource type="Resource" id="Resource_cndc5"]
script = ExtResource("1_ku56k")
text = "[wave]WHO CARES![/wave] YOU! What did you do to the office? Where are all the workers?"
speaker1 = ExtResource("4_d73fm")
speaker2 = ExtResource("3_b73wo")
metadata/_custom_type_script = "uid://dxc3ltvbb58ih"

[sub_resource type="Resource" id="Resource_b73wo"]
script = ExtResource("1_ku56k")
text = "What are you talking about? You must have met them all on the way here. "
speaker1 = ExtResource("4_d73fm")
speaker2 = ExtResource("3_b73wo")
speaker_turn = 2
metadata/_custom_type_script = "uid://dxc3ltvbb58ih"

[sub_resource type="Resource" id="Resource_kkk52"]
script = ExtResource("1_ku56k")
text = "Also, I don't recall approving any new hires... are you sure you aren't mistaken?"
speaker1 = ExtResource("4_d73fm")
speaker2 = ExtResource("3_b73wo")
speaker_turn = 2
metadata/_custom_type_script = "uid://dxc3ltvbb58ih"

[sub_resource type="Resource" id="Resource_d73fm"]
script = ExtResource("1_ku56k")
text = "What? But... but I got the email..."
