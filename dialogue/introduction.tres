[sub_resource type="Resource" id="Resource_cynjg"]
script = ExtResource("1_25ah2")
text = "It's my first day! I've got to make a good first impression..."
speaker1 = ExtResource("2_cynjg")
speaker2 = ExtResource("3_d07se")
metadata/_custom_type_script = "uid://dxc3ltvbb58ih"

[sub_resource type="Resource" id="Resource_d07se"]
script = ExtResource("1_25ah2")
text = "Relax, I'm sure you'll do fine."
speaker1 = ExtResource("2_cynjg")
speaker2 = ExtResource("3_d07se")
speaker_turn = 2
metadata/_custom_type_script = "uid://dxc3ltvbb58ih"

[sub_resource type="Resource" id="Resource_e8i4i"]
script = ExtResource("1_25ah2")
text = "[wave]Eep![/wave] Why are you talking?"
speaker1 = ExtResource("2_cynjg")
speaker2 = ExtResource("3_d07se")
metadata/_custom_type_script = "uid://dxc3ltvbb58ih"

[sub_resource type="Resource" id="Resource_ovf0q"]
script = ExtResource("1_25ah2")
text = "That's rude... I'm going to pretend that I didn't hear that."
speaker1 = ExtResource("2_cynjg")
speaker2 = ExtResource("3_d07se")
speaker_turn = 2
metadata/_custom_type_script = "uid://dxc3ltvbb58ih"

[sub_resource type="Resource" id="Resource_wjmxj"]
script = ExtResource("1_25ah2")
text = "W... why...? How? Am I hallucinating from the stress?"
speaker1 = ExtResource("2_cynjg")
speaker2 = ExtResource("3_d07se")
metadata/_custom_type_script = "uid://dxc3ltvbb58ih"

[sub_resource type="Resource" id="Resource_2c6lp"]
script = ExtResource("1_25ah2")
text = "Hah! You wish. Anyway, I'm the least of your concerns right now. Go ahead and wander around. You'll see what I'm talking about."
speaker1 = ExtResource("2_cynjg")
speaker2 = ExtResource("3_d07se")
speaker_turn = 2
metadata/_custom_type_script = "uid://dxc3ltvbb58ih"

